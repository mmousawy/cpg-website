{
  "installCommand": "npx pnpm@11.10.0 install --frozen-lockfile",
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 0; fi; case \"$VERCEL_GIT_COMMIT_REF\" in release-please--*) exit 0 ;; esac; if [ -z \"$VERCEL_GIT_PULL_REQUEST_ID\" ]; then exit 0; fi; exit 1",
  "crons": [
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/cron/revalidate-events",
      "schedule": "1 13 * * *"
    },
    {
      "path": "/api/cron/revalidate-events",
      "schedule": "1 17 * * *"
    },
    {
      "path": "/api/cron/cleanup-deleted-content",
      "schedule": "0 3 * * 0"
    }
  ]
}
