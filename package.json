{
  "name": "cpg-website",
  "version": "1.31.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:light": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:clean": "rm -rf .next/cache/.tsbuildinfo && tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run lint && npm run typecheck:clean && npm run test:run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "scrape:all": "npx tsx scripts/scrape-uitagenda-events.ts && npx tsx scripts/scrape-tpc-events.ts && npx tsx scripts/scrape-cameranu-events.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "blurhash": "^2.0.5",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "focus-trap-react": "^12.0.2",
    "image-size": "^2.0.2",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "photoswipe": "^5.4.4",
    "piexifjs": "^1.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.79.0",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.8.3",
    "resend": "^6.12.4",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "critters": "^0.0.25",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8",
    "supabase": "^2.106.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=999999"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  }
}
