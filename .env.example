# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM_NAME=Creative Photography Group
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_REPLY_TO_NAME=Creative Photography Group
EMAIL_REPLY_TO_ADDRESS=hello@yourdomain.com
EMAIL_ASSETS_URL=https://yourdomain.com

# reCAPTCHA (optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Encryption key for secure links (32 hex characters)
ENCRYPTION_KEY=

# Vercel CRON jobs:
CRON_SECRET=

# Encryption key for secure links (32 hex characters)
ENCRYPT_KEY=

# IP addresses to block (comma-separated list)
BLACKLIST_IPS=

# Vercel token for deployment
VERCEL_TOKEN=
# Vercel organization (team) ID
VERCEL_ORG_ID=
# Vercel project ID
VERCEL_PROJECT_ID=

# Revalidation secret for /api/revalidate-all (must match the deployed app)
REVALIDATION_SECRET=

# Optional: production site URL for scrapers. When you run scrapers locally with prod Supabase,
# set this to https://your-domain.com so post-run revalidation hits Vercel (not localhost).
# If unset, NEXT_PUBLIC_SITE_URL is used.
SCRAPER_REVALIDATE_URL=

# Event scrapers (create a bot user in Supabase Auth first)
SCRAPER_USER_ID=